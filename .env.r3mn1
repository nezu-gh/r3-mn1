# R3-MN1 local-first environment
# Usage:  cp .env.r3mn1 .env   (or symlink)
#
# All three inference services run as Docker containers on the local VM
# and expose OpenAI-compatible /v1 endpoints.

# ---------------------------------------------------------------------------
# Provider selection
# ---------------------------------------------------------------------------
PROVIDER=pipecat

# Pipeline mode: lean (default) — VAD → STT → LLM → TTS only.
#   full — adds context trimmer, memory, vision, intent router, TTS chunker.
# PIPELINE_MODE=lean

# ---------------------------------------------------------------------------
# Barge-in
# ---------------------------------------------------------------------------
# Master switch. 0 = standard behaviour (bot talks uninterrupted, user speech
# during bot speech becomes the next turn). 1 = interrupt mid-speech (enables
# AEC + queue drain + pipecat interruption).
BARGE_IN_ENABLED=1
# Minimum words in an utterance to trigger pipecat's InterruptionFrame.
# 1 = any word interrupts; raise to 2–3 if speaker-to-mic echo causes
# self-interrupts. Only relevant when BARGE_IN_ENABLED=1.
MIN_INTERRUPT_WORDS=1
# Seconds of VAD silence before the user turn ends (lower = snappier reply,
# but may cut off pauses mid-thought). Default 0.6.
# USER_SPEECH_TIMEOUT=0.6
# VAD sensitivity: Silero confidence (0.5 default), start_secs (0.1 default
# — how long sustained speech before trigger), stop_secs (0.2 default).
# VAD_CONFIDENCE=0.5
# VAD_START_SECS=0.1
# VAD_STOP_SECS=0.2

# ---------------------------------------------------------------------------
# Profile
# ---------------------------------------------------------------------------
REACHY_MINI_CUSTOM_PROFILE=r3_mn1

# ---------------------------------------------------------------------------
# Local VM
# ---------------------------------------------------------------------------
LOCAL_VM_IP=192.168.178.155

# ---------------------------------------------------------------------------
# LLM — Qwen3.6-35B-A3B via ik-llama.cpp
# ---------------------------------------------------------------------------
LLM_BASE_URL=http://192.168.178.155:3443/v1
# Exact model ID as returned by /v1/models. Verify with:
#   curl http://192.168.178.155:3443/v1/models
MODEL_NAME=unsloth/Qwen3.6-35B-A3B

# ---------------------------------------------------------------------------
# STT / ASR — Qwen3-ASR via qwen-asr-serve (vLLM)
# ---------------------------------------------------------------------------
ASR_BASE_URL=http://192.168.178.155:8015/v1
ASR_MODEL=Qwen/Qwen3-ASR-0.6B

# ---------------------------------------------------------------------------
# TTS — Qwen3-TTS via Qwen3-TTS-Openai-Fastapi
# ---------------------------------------------------------------------------
TTS_BASE_URL=http://192.168.178.155:7034/v1
TTS_MODEL=qwen3-tts

# ---------------------------------------------------------------------------
# Reachy Mini robot
# ---------------------------------------------------------------------------
# Robot host/IP. Falls back to SDK auto-detect on the local network if unset.
REACHY_ROBOT_NAME=192.168.178.127

# ---------------------------------------------------------------------------
# OpenAI fallback (leave blank to disable; only needed for --provider openai)
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=
